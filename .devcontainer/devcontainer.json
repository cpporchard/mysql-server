{
  "name": "mysql-server-dev",
  "build": { "dockerfile": "Dockerfile", "context": ".." },

  "forwardPorts": [3306, 33060],

  "runArgs": [
    "--cap-add=SYS_PTRACE",
    "--security-opt=seccomp:unconfined"
  ],

  "remoteUser": "root",
  "postCreateCommand": "cmake --version && gdb --version"
}
