{
  "name": "mysql-server-dev",
  "build": { "dockerfile": "Dockerfile", "context": ".." },

  // Expose MySQL’s default ports (optional – remove if you don’t need them yet)
  "forwardPorts": [3306, 33060],

  // Allow ptrace so GDB works
  "runArgs": [
    "--cap-add=SYS_PTRACE",
    "--security-opt=seccomp:unconfined"
  ],

  // Work as root to keep things simple
  "remoteUser": "root",

  // Quick sanity check after the image is built
  "postCreateCommand": "cmake --version && gdb --version"
}
